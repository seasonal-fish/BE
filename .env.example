# PostgreSQL 접속 문자열 (pgvector 확장이 설치된 DB)
# 형식: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# OpenAI API 키 (임베딩: text-embedding-3-small / 판정·생성: gpt-4o-mini)
# 미설정 시 서버가 기동 시점에 즉시 종료됩니다.
OPENAI_API_KEY=sk-your-key-here

# (선택) 통합 테스트용 DB 접속 문자열. 설정 시 `make test-integration` 이 실제 DB 에 붙어 동작.
# 미설정 시 통합 테스트는 자동으로 건너뜁니다.
# TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/postgres
